<div id="watermark-overlay" style="
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
    overflow: hidden;
">
    <div style="
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-45deg);
        transform-origin: center center;
        font-size: 24px;
        color: rgba(128, 128, 128, 0.15);
        white-space: nowrap;
        font-family: Arial, sans-serif;
        letter-spacing: 2px;
        user-select: none;
        pointer-events: none;
    ">
        $watermarkText
    </div>
</div>

<script type="text/javascript">
    (function() {
        var watermarkText = '$watermarkText';
        var overlay = document.getElementById('watermark-overlay');
        if (!overlay) return;

        var container = overlay.firstElementChild;
        if (!container) return;

        function createWatermarkGrid() {
            var html = '';
            var spacing = 300;
            var cols = Math.ceil(window.innerWidth / spacing) + 2;
            var rows = Math.ceil(window.innerHeight / spacing) + 2;

            for (var i = -1; i < rows; i++) {
                for (var j = -1; j < cols; j++) {
                    html += '<div style="' +
                        'position: absolute;' +
                        'top: ' + (i * spacing) + 'px;' +
                        'left: ' + (j * spacing) + 'px;' +
                        'transform: rotate(-45deg);' +
                        'font-size: 14px;' +
                        'color: rgba(128, 128, 128, 0.08);' +
                        'white-space: nowrap;' +
                        'font-family: Arial, sans-serif;' +
                        'letter-spacing: 1px;' +
                        'user-select: none;' +
                        'pointer-events: none;' +
                    '">' + watermarkText + '</div>';
                }
            }
            overlay.innerHTML = html;
        }

        createWatermarkGrid();
        window.addEventListener('resize', createWatermarkGrid);
    })();
</script>
