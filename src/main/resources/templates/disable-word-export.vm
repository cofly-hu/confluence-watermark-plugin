<script type="text/javascript">
    (function() {
        function disableWordExport() {
            var links = document.querySelectorAll('a[href*="exportword"], a[href*="exportWord"], a[data-content-type="word"]');
            links.forEach(function(link) {
                link.style.display = 'none';
                link.disabled = true;
            });

            var menuItems = document.querySelectorAll('[id*="export-word"], [class*="export-word"], [data-type="word"]');
            menuItems.forEach(function(item) {
                item.style.display = 'none';
            });

            var exportLinks = document.querySelectorAll('a[href*="exportWord"], a[href*="exportword"]');
            exportLinks.forEach(function(link) {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    alert('Word 导出功能已被禁用');
                    return false;
                });
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', disableWordExport);
        } else {
            disableWordExport();
        }

        setInterval(disableWordExport, 2000);
    })();
</script>
